APP_NAME=Elephenv
APP_ENV=testing
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=elephenv_test
DB_USER=root
DB_PASSWORD=secret

CACHE_ENABLED=true
CACHE_DRIVER=file
CACHE_TTL=1800

MAIL_HOST=smtp.localhost
MAIL_PORT=1025
MAIL_USERNAME=test
MAIL_PASSWORD=test

QUEUE_CONNECTION=sync
LOG_LEVEL=debug

PI_VALUE=3.14159
FEATURE_X_ENABLED=false
EMPTY_VALUE=
API_TIMEOUT=30

ARRAY_EXAMPLE[host]=localhost
ARRAY_EXAMPLE[port]=5432
QUOTED_VALUE="hello world"
TRIMMED_VALUE=   value with leading spaces
COMMENTED_VALUE=value # this is a comment
BOOLEAN_ONE=1
BOOLEAN_ZERO=0
NULL_STRING=null
PASSWORD_HASH="abc#123"
EXPORTED_VALUE=yes
